{
  "name": "noto",
  "productName": "Noto",
  "version": "0.1.2",
  "description": "Markdown note-taking application focused on simplicity and ease of use.",
  "main": "main.js",
  "homepage": "https://github.com/peetupollari/noto",
  "repository": {
    "type": "git",
    "url": "https://github.com/peetupollari/noto.git"
  },
  "bugs": {
    "url": "https://github.com/peetupollari/noto/issues"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --remote-debugging-port=9223",
    "build:editor": "esbuild src/codemirror-obsidian.mjs --bundle --format=iife --target=chrome120 --outfile=src/codemirror-obsidian.bundle.js",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build:editor && electron-builder --dir",
    "dist": "npm run build:editor && electron-builder --publish never",
    "dist:win": "npm run build:editor && electron-builder --win nsis --publish never",
    "release:win": "npm run build:editor && electron-builder --win nsis --publish always"
  },
  "keywords": [
    "electron",
    "desktop",
    "app"
  ],
  "author": "Noto",
  "license": "MIT",
  "devDependencies": {
    "electron": "41.2.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "supabase": "^2.76.15"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.3",
    "@supabase/supabase-js": "^2.97.0",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1"
  },
  "build": {
    "appId": "com.noto_notes.noto",
    "productName": "Noto",
    "artifactName": "${productName}-Setup-${arch}.${ext}",
    "asar": true,
    "compression": "maximum",
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "notologo-ico.ico",
        "to": "notologo-ico.ico"
      },
      {
        "from": "supabase.config.json",
        "to": "supabase.config.json"
      },
      {
        "from": "cloud-storage.config.json",
        "to": "cloud-storage.config.json"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "peetupollari",
        "repo": "noto",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "notologo-ico.ico",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Noto",
      "installerIcon": "notologo-ico.ico",
      "uninstallerIcon": "notologo-ico.ico",
      "uninstallDisplayName": "Noto"
    }
  }
}
